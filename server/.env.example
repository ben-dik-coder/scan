# Kopier denne filen til .env (samme mappe: server/.env) og fyll inn.
# Viktig: Kontrakt-RAG leser KUN disse tre – ikke VITE_SUPABASE_* fra frontend.

OPENAI_API_KEY=sk-...din-openai-nøkkel

SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...eller-annen-service_role-fra-supabase-dashboard
# Valgfritt: OPENAI_PDF_SUMMARY_MODEL=gpt-4o-mini (AI-oppsummering før PDF-eksport fra VeiAi)
# Valgfritt: OPENAI_CONTRACT_MODEL=gpt-5-mini (kontrakt-chat etter RAG)
# Embedding (må være lik ved ingest og i DB – standard 1536 for text-embedding-3-small)
# CONTRACT_EMBEDDING_MODEL=text-embedding-3-small
# CONTRACT_EMBEDDING_DIM=1536
# RAG-kvalitet (høy standard som standard; sett til 0/false for å spare API-kall):
# CONTRACT_RAG_QUERY_EXPAND=1 (utvid søket før embedding; 0=av)
# CONTRACT_RAG_RERANK=1 (LLM velger beste utdrag; 0=av)
# CONTRACT_RAG_RERANK_MODEL=gpt-4o-mini
# CONTRACT_RAG_POOL_MATCH_COUNT=32 (vektor-treff i pool før rerank, maks 80)
# CONTRACT_RAG_MERGE_POOL_MAX=44 (maks utdrag etter vektor+nøkkelord før rerank)
# CONTRACT_RAG_MAX_CONTEXT_CHUNKS=12 (utdrag til svarmodell etter rerank)
# CONTRACT_RAG_MAX_COMPLETION_TOKENS=1100 (svarlengde fra kontrakt-modellen; øk ved behov)
# CONTRACT_RAG_TEMPERATURE=0.35 (lavere = mer konservativt svar; gpt-5 bruker ikke alltid temperature)
# CONTRACT_RAG_RERANK_INPUT_MAX=32 (maks utdrag sendt til rerank-modellen)
# CONTRACT_RAG_KEYWORD_SUPPLEMENT=14 (ekstra rader fra nøkkelord-ILIKE)
# CONTRACT_RAG_MIN_SIMILARITY=0.1 (filtrerer svake vektor-treff; 0 = av. Tomt treff → retry med 0)
# Valgfritt ved ingest: CONTRACT_INGEST_CHUNK_SIZE=1400 CONTRACT_INGEST_CHUNK_OVERLAP=280
# Valgfritt:
# OPENAI_MODEL=gpt-5-mini
# Sti til kontrakts-/avtaletekst som legges inn i systemprompt (standard: server/contract-context.txt)
# CONTRACT_CONTEXT_PATH=/full/sti/til/kontrakt.txt
# Lokal standard 8787; Railway/Render setter ofte PORT automatisk
# PDF_SERVER_PORT=8787
# LISTEN_HOST=0.0.0.0
