# Kopier til .env og fyll inn (server/.env lastes automatisk ved oppstart)
OPENAI_API_KEY=
# Valgfritt:
# OPENAI_MODEL=gpt-4o
# Sti til kontrakts-/avtaletekst som legges inn i systemprompt (standard: server/contract-context.txt)
# CONTRACT_CONTEXT_PATH=/full/sti/til/kontrakt.txt
# Lokal standard 8787; Railway/Render setter ofte PORT automatisk
# PDF_SERVER_PORT=8787
# LISTEN_HOST=0.0.0.0
