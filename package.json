{
  "name": "scanix",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:all": "bash ./start-local-dev.sh",
    "dev:http": "USE_HTTP=1 vite",
    "dev:lan": "USE_HTTP=1 vite",
    "hint:net": "node scripts/dev-network-hint.mjs",
    "build": "vite build",
    "build:ios": "npm run build && npx cap sync ios",
    "watch:dist": "VITE_WATCH_DIST=1 vite build",
    "build:watch": "npm run watch:dist",
    "preview": "vite preview",
    "preview:lan": "USE_HTTP=1 vite preview",
    "generate:offline-vegref": "node scripts/generate-offline-vegref-package.mjs",
    "validate:vegref-parity": "node scripts/validate-vegref-parity.mjs",
    "debug:boot": "npm run build && node scripts/debug-boot-console.mjs",
    "pdf-server": "npm run start --prefix server",
    "ingest-contract": "npm run ingest-contract-pdf --prefix server --",
    "fix:registrering-icon": "node scripts/fix-registrering-alpha.mjs",
    "registrering:white-alpha": "node scripts/registrering-white-to-alpha.mjs",
    "kamera:white-alpha": "node scripts/registrering-white-to-alpha.mjs public/icons/kamera.png",
    "kontraktai:white-alpha": "node scripts/registrering-white-to-alpha.mjs public/icons/kontraktai.png",
    "album:white-alpha": "node scripts/registrering-white-to-alpha.mjs public/icons/album.png",
    "album:edge-dark-alpha": "node scripts/edge-dark-to-alpha.mjs public/icons/album.png",
    "delsky:white-alpha": "node scripts/registrering-white-to-alpha.mjs public/icons/delsky.png",
    "delsky:edge-dark-alpha": "node scripts/edge-dark-to-alpha.mjs public/icons/delsky.png",
    "icons:normalize-home": "node scripts/normalize-home-icons.mjs",
    "kamera:edge-dark-alpha": "node scripts/edge-dark-to-alpha.mjs public/icons/kamera.png"
  },
  "devDependencies": {
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "playwright": "^1.49.1",
    "sharp": "^0.34.5",
    "vite": "^7.3.2",
    "vite-plugin-pwa": "^1.2.0"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@supabase/supabase-js": "^2.100.1",
    "exifr": "^7.1.3",
    "jspdf": "^4.2.1",
    "leaflet": "^1.9.4",
    "xlsx": "^0.18.5"
  }
}
