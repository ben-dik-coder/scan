# Kopier denne fila til .env (samme mappe som package.json) og fyll inn fra Supabase.
# Raskest: kopier innhold fra lim-inn.env → lagre som .env.local (dev) eller lim-inn-produksjon.env → .env.production.local (build).
# Utvidet mal med forklaringer: .env.lim-inn.example
# Vite leser .env ved npm run build — ikke bare .env.example.
# Viktig: tom `VITE_MAPTILER_API_KEY=` i .env.production.local overstyrer .env.local → kart OK på localhost (dev), tomt i Xcode-bygg.
# (Du kan også bruke .env.local i stedet for .env.)
# Project Settings → API → Project URL og anon / publishable key

VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=lim_inn_din_lange_nøkkel_her

# Valgfritt: egen API + R2 for app-state og bildeopplasting (unngår Supabase Storage/Postgres for disse).
# Se API-kontrakt i kilde: src/scanixCloudApi.js — inkl. /v1/session-shares og /v1/standalone-photos/folder.
# Med Supabase-auth: la VITE_SCANIX_CLOUD_BEARER_TOKEN være tom — klienten sender Supabase access_token.
# Uten Supabase: sett statisk bearer for test (produksjon bør bruke kortlevde tokens fra egen auth).
# VITE_SCANIX_CLOUD_API_BASE_URL=https://api.dittdomene.no
# Lokalt (start API: npm run pdf-server): VITE_SCANIX_CLOUD_API_BASE_URL=http://127.0.0.1:8787
# VITE_SCANIX_CLOUD_BEARER_TOKEN=

# Valgfritt: MapTiler Cloud for bakgrunnskart i appen (vektorfliser via @maptiler/leaflet-maptilersdk).
# Gratis nøkkel: https://cloud.maptiler.com/account/keys/
# iOS (Capacitor): appen lastes fra https://localhost — legg inn det (eller «ingen URL-begrensning») i MapTiler-nøkkelens URL-liste, ellers blokkeres fliser/style.json.
# Uten nøkkel brukes OpenStreetMap-raster (fallback).
# Frittstående HTML-eksport bruker MapTiler-raster eller OSM (ingen vektor-SDK i fila).
# VITE_MAPTILER_API_KEY=din_nøkkel_her
# Kart-ID fra https://cloud.maptiler.com/maps/ (standard: base-v4). Overstyr f.eks. streets-v4.
# VITE_MAPTILER_MAP_ID=base-v4
# Mørkt raster-underlag når brukeren velger «Mørkt kart» i øktkart (standard: streets-v2-dark).
# VITE_MAPTILER_MAP_ID_DARK=streets-v2-dark
# Valgfritt: MapTiler som raster-PNG i stedet for vektor (f.eks. ustabil WebGL i WKWebView).
# VITE_MAPTILER_PREFER_RASTER_ON_NATIVE=true  → kun installert app (Capacitor)
# VITE_MAPTILER_FORCE_RASTER=true             → raster overalt inkl. nettleser

# Server (ikke VITE_*): maks ventetid på OpenAI i ms (standard 720000 = 12 min).
# OPENAI_TIMEOUT_MS=720000

# NyLead AI-agent (kun server — aldri VITE_*)
# OPENAI_API_KEY=sk-...
# OPENAI_AGENT_MODEL=gpt-5-mini

# AI-agent (default AV — sett begge til true for å skru på)
# AGENT_ENABLED=true
# NEXT_PUBLIC_AGENT_ENABLED=true
