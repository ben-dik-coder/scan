# Valgfritt: for npm run db:billing (Supabase → Settings → Database → Connection string URI)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Valgfritt fallback hvis bruker ikke har koblet Gmail/Outlook/SMTP
RESEND_API_KEY=re_your_key
RESEND_FROM_EMAIL=tilbud@dittdomene.no

# Gmail OAuth (Google Cloud Console → OAuth 2.0) — plattform-eier setter opp én gang
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Outlook OAuth (valgfritt) — plattform-eier setter opp én gang i Azure Portal
# Brukere med privat Hotmail/Outlook trenger IKKE dette — de kan bruke app-passord i appen
# Se docs/OUTLOOK_SETUP.md
# Redirect URI i Azure: {NEXT_PUBLIC_APP_URL}/api/email/callback/microsoft
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# Krypter lagrede OAuth-tokens og SMTP app-passord (minst 32 tegn, tilfeldig streng)
EMAIL_TOKEN_SECRET=change-me-to-a-long-random-string

CRON_SECRET=change-me-to-a-long-random-string

# Optional: first user with this email gets admin on signup (set in Supabase SQL instead if preferred)
# ADMIN_EMAIL=admin@example.com

NEXT_PUBLIC_APP_URL=http://localhost:3003

# Test-betaling uten Stripe (true = alltid fake; false = alltid ekte Stripe når nøkler finnes)
BILLING_FAKE=true

# Gratis tilgang uten betaling (kommaseparert, f.eks. plattform-eier)
BILLING_FREE_EMAILS=ben-dik@hotmail.com

# Sitteplasser (marketing-banner + checkout-stopp ved fullt)
SUBSCRIBER_CAP=300
# Test-visning i banner (f.eks. 10) — teller fortsatt ekte abonnenter i DB for «fullt»
SUBSCRIBER_COUNT_OVERRIDE=10

# Stripe (abonnement — én månedlig pris: NyLead 499 kr/mnd)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE=
# Valgfritt: eldre priser for eksisterende abonnenter i Stripe
# STRIPE_PRICE_START=
# STRIPE_PRICE_PRO=
# STRIPE_PRICE_AGENCY=

# Vises i personvern og vilkår (fyll inn ditt firma)
NEXT_PUBLIC_LEGAL_NAME=North Digital Norge
NEXT_PUBLIC_LEGAL_ORG_NR=
NEXT_PUBLIC_LEGAL_ADDRESS=Norge
NEXT_PUBLIC_LEGAL_EMAIL=post@nylead.no

# Demo uten innlogging (true = demo for maler/kampanjer)
NEXT_PUBLIC_DEMO_MODE=true

# Hent firma live fra Brønnøysund API på /app (false = bruk demo-firma)
NEXT_PUBLIC_BRREG_LIVE=true

# Etter bulk-import til Supabase: true | false | auto (standard auto = DB ved ≥10k rader)
# BRREG_USE_DB=auto

# Nettside-skanning (Google Custom Search + SerpAPI)
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=
# Google-søk + Facebook Profile API (https://serpapi.com/facebook-profile-api)
SERPAPI_API_KEY=
# SerpAPI er AV som standard — sett true for bevisst bruk (krever også API-nøkkel)
# Søkerekkefølge: Serper Places → Serper → DuckDuckGo → Google CSE → SerpAPI (sist)
SERPAPI_ENABLED=
# Legacy opt-out (overstyrer SERPAPI_ENABLED)
SERPAPI_DISABLED=
# Google-søk via Serper (https://serper.dev) — alternativ til SerpAPI/CSE
SERPER_API_KEY=

# 1881 telefon-oppslag (https://www.api1881.no) — primary + secondary subscription key
API1881_SUBSCRIPTION_KEY=
API1881_SUBSCRIPTION_KEY_PRIMARY=
API1881_SUBSCRIPTION_KEY_SECONDARY=
