# Kopier denne fila til .env (samme mappe som package.json) og fyll inn fra Supabase.
# Vite leser .env ved npm run build — ikke bare .env.example.
# (Du kan også bruke .env.local i stedet for .env.)
# Project Settings → API → Project URL og anon / publishable key

VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=lim_inn_din_lange_nøkkel_her

# Server (ikke VITE_*): maks ventetid på OpenAI i ms (standard 720000 = 12 min).
# OPENAI_TIMEOUT_MS=720000
