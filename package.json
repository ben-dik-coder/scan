{
  "name": "nye-firma-plattform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev:scan": "vite",
    "dev:all": "bash ./start-local-dev.sh",
    "dev:http": "USE_HTTP=1 vite",
    "dev:lan": "USE_HTTP=1 vite",
    "hint:net": "node scripts/dev-network-hint.mjs",
    "build:scan": "vite build",
    "build:ios": "npm run build && npx cap sync ios",
    "watch:dist": "VITE_WATCH_DIST=1 vite build",
    "build:watch": "npm run watch:dist",
    "preview": "vite preview",
    "preview:lan": "USE_HTTP=1 vite preview",
    "generate:offline-vegref": "node scripts/generate-offline-vegref-package.mjs",
    "validate:vegref-parity": "node scripts/validate-vegref-parity.mjs",
    "debug:boot": "npm run build && node scripts/debug-boot-console.mjs",
    "pdf-server": "npm run start --prefix server",
    "ingest-contract": "npm run ingest-contract-pdf --prefix server --",
    "fix:registrering-icon": "node scripts/fix-registrering-alpha.mjs",
    "registrering:white-alpha": "node scripts/registrering-white-to-alpha.mjs",
    "kamera:white-alpha": "node scripts/registrering-white-to-alpha.mjs public/icons/kamera.png",
    "kontraktai:white-alpha": "node scripts/registrering-white-to-alpha.mjs public/icons/kontraktai.png",
    "album:white-alpha": "node scripts/registrering-white-to-alpha.mjs public/icons/album.png",
    "album:edge-dark-alpha": "node scripts/edge-dark-to-alpha.mjs public/icons/album.png",
    "delsky:white-alpha": "node scripts/registrering-white-to-alpha.mjs public/icons/delsky.png",
    "delsky:edge-dark-alpha": "node scripts/edge-dark-to-alpha.mjs public/icons/delsky.png",
    "icons:normalize-home": "node scripts/normalize-home-icons.mjs",
    "kamera:edge-dark-alpha": "node scripts/edge-dark-to-alpha.mjs public/icons/kamera.png",
    "dev": "next dev -p 3003",
    "dev:clean": "rm -rf .next && next dev -p 3003",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:billing": "node scripts/migrate-billing.mjs",
    "db:agent": "node scripts/migrate-agent.mjs",
    "db:serper": "node scripts/migrate-serper-usage.mjs",
    "brreg:bulk-import": "node scripts/brreg-bulk-import.mjs",
    "brreg:backfill-geo": "node scripts/backfill-company-geo.mjs",
    "brreg:backfill-roles": "node scripts/backfill-company-roles.mjs",
    "verify:website-scan": "npx tsx scripts/verify-website-scan-matching.ts",
    "eval:website-scan": "npx tsx scripts/eval-website-scan-batch.ts",
    "eval:phone-recall": "npx tsx scripts/eval-serpapi-phone-recall.ts",
    "eval:facebook-discovery": "npx tsx scripts/eval-facebook-discovery.ts",
    "eval:agent-scenarios": "npx tsx scripts/eval-agent-scenarios.ts"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@capacitor/network": "^8.0.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@maptiler/leaflet-maptilersdk": "^4.1.1",
    "@maptiler/sdk": "^4.0.1",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "clsx": "^2.1.1",
    "exifr": "^7.1.3",
    "jspdf": "^4.2.1",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "lucide-react": "^1.17.0",
    "next": "14.2.35",
    "nodemailer": "^8.0.10",
    "openai": "^4.104.0",
    "react": "^18",
    "react-dom": "^18",
    "resend": "^6.12.4",
    "stripe": "^17.7.0",
    "tailwind-merge": "^3.6.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "pg": "^8.16.0",
    "playwright": "^1.49.1",
    "postcss": "^8",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vite": "^7.3.2",
    "vite-plugin-pwa": "^1.2.0"
  }
}
