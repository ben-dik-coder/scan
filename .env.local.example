NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Valgfritt fallback hvis bruker ikke har koblet Gmail/Outlook
RESEND_API_KEY=re_your_key
RESEND_FROM_EMAIL=tilbud@dittdomene.no

# Gmail OAuth (Google Cloud Console → OAuth 2.0)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Outlook OAuth (Azure App registration)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# Krypter lagrede OAuth-tokens (minst 32 tegn, tilfeldig streng)
EMAIL_TOKEN_SECRET=change-me-to-a-long-random-string

CRON_SECRET=change-me-to-a-long-random-string

# Optional: first user with this email gets admin on signup (set in Supabase SQL instead if preferred)
# ADMIN_EMAIL=admin@example.com

NEXT_PUBLIC_APP_URL=http://localhost:3003

# Test-betaling uten Stripe (true = alltid fake; uten Stripe i dev skrus det på automatisk)
BILLING_FAKE=true

# Stripe (abonnement — opprett månedlige priser i Stripe Dashboard)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_START=
STRIPE_PRICE_PRO=
STRIPE_PRICE_AGENCY=

# Vises i personvern og vilkår (fyll inn ditt firma)
NEXT_PUBLIC_LEGAL_NAME=NyLead AS
NEXT_PUBLIC_LEGAL_ORG_NR=
NEXT_PUBLIC_LEGAL_ADDRESS=Norge
NEXT_PUBLIC_LEGAL_EMAIL=post@nylead.no

# Demo uten innlogging (true = demo for maler/kampanjer)
NEXT_PUBLIC_DEMO_MODE=true

# Hent firma live fra Brønnøysund API på /app (false = bruk demo-firma)
NEXT_PUBLIC_BRREG_LIVE=true

# Nettside-skanning (Google Custom Search + SerpAPI)
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=
SERPAPI_API_KEY=
